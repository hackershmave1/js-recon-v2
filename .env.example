# Slice-1 configuration. Copy to .env for local dev; docker-compose defaults match these.
RECON_ENV=local
RECON_LOG_LEVEL=INFO

# Postgres. The app/workers use the non-superuser role (RLS enforced); the admin
# role owns the schema and runs migrations. Both are provisioned by migration 0001.
RECON_DATABASE_URL=postgresql+psycopg2://recon_app:recon_app@localhost:5432/recon
RECON_DATABASE_ADMIN_URL=postgresql+psycopg2://recon:recon@localhost:5432/recon

# Redis (broker + event log + heartbeat)
RECON_REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO locally, S3 in prod). Bytes never live in a row (REQ-D2).
RECON_S3_ENDPOINT_URL=http://localhost:9000
RECON_S3_ACCESS_KEY=recon
RECON_S3_SECRET_KEY=recon-secret
RECON_S3_BUCKET=recon-artifacts
RECON_S3_REGION=us-east-1

# Realtime / durability knobs
RECON_HEARTBEAT_INTERVAL_SECONDS=5
RECON_HEARTBEAT_STALL_THRESHOLD_SECONDS=30
RECON_EVENT_STREAM_MAXLEN=10000

# Queue retry policy (REQ-Q2)
RECON_RETRY_MAX_ATTEMPTS=5
RECON_RETRY_BASE_DELAY_SECONDS=1.0
RECON_RETRY_MAX_DELAY_SECONDS=60.0
